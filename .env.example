# Copy this file to `.env.local` for local development.
# Do not commit `.env.local`.

# Public origin for generated URLs.
# Used for canonical links, Markdown exports, llms.txt links, contextual AI
# actions, and the MCP endpoint install URL.
# Local development can use http://localhost:3000. Production should use your
# deployed docs site URL, for example https://docs.example.com.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Optional. Enables the in-app AI assistant.
# Leave this empty or unset if you want search, Markdown exports, llms.txt, and
# the MCP endpoint without AI chat. API usage is billed by your AI provider.
OPENAI_API_KEY=

# Optional. Overrides the default model used by the AI assistant API route.
# Keep this aligned with a model your API key can access.
OPENAI_MODEL=gpt-5.4-mini
